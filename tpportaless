local function realisticTeleport()
    if not running or not selectedPlayer or not selectedPlayer.Character or isCooldown then 
        if isCooldown then notifySpam() end
        return 
    end

    isCooldown = true
    local myChar = localPlayer.Character; local targetChar = selectedPlayer.Character
    local myRoot = myChar:FindFirstChild("HumanoidRootPart"); local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    
    if myRoot and targetRoot then
        playEffectSound(TELEPORT_SOUND_ID, 1)
        local exitPos = targetRoot.CFrame * CFrame.new(0, 9, 0)
        
        createRealisticPortal(myRoot.CFrame * CFrame.new(0, 8.5, 0), false, 2.5) 
        createRealisticPortal(exitPos, false, 2.5)

        local originalParts = {}
        for _, part in pairs(myChar:GetDescendants()) do
            if part:IsA("BasePart") then
                originalParts[part] = {Size = part.Size, Trans = part.Transparency}
                TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = part.Size * Vector3.new(0.1, 10, 0.1), Transparency = 1}):Play()
            end
        end
        
        task.wait(0.6)
        if running and targetRoot.Parent then 
            myRoot.CFrame = exitPos
            task.wait(0.1)
            for part, data in pairs(originalParts) do if part and part.Parent then
                local targetTrans = (part.Name == "HumanoidRootPart") and 1 or data.Trans
                TweenService:Create(part, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = data.Size, Transparency = targetTrans}):Play()
            end end
        end
    end
    
    task.delay(1.5, function() isCooldown = false end) 
end

